<Configuration>
  <!--
    booch-win ワンライナー bootstrap の手動スモーク用 Windows Sandbox 設定。
    使い捨て・ほぼクリーンな Windows でネットワーク有効。閉じれば全て破棄される。

    使い方: このファイルをダブルクリック（要 Windows Sandbox 機能の有効化）。
    手順は tests/sandbox/manual-smoke.md を参照。

    ※ローカルの未 push 版 win.ps1 を試したい場合は、下の MappedFolders コメントを外し
      HostFolder を自分の clone パスへ書き換える（既定はリポジトリ非依存にするため無効）。
  -->
  <Networking>Enable</Networking>
  <!--
  <MappedFolders>
    <MappedFolder>
      <HostFolder>C:\path\to\your\booch-win</HostFolder>
      <SandboxFolder>C:\booch-win</SandboxFolder>
      <ReadOnly>true</ReadOnly>
    </MappedFolder>
  </MappedFolders>
  -->
  <LogonCommand>
    <Command>powershell.exe -NoExit -ExecutionPolicy Bypass -NoProfile -Command "Write-Host 'booch-win smoke sandbox ready. 手順: tests/sandbox/manual-smoke.md' -ForegroundColor Cyan"</Command>
  </LogonCommand>
</Configuration>
